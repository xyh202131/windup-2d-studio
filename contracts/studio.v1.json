{
  "$schema": "./studio.schema.json",
  "version": "1.0.0",
  "previewFps": 8,
  "masterSize": 1024,
  "frameSize": 512,
  "frameCounts": [8, 12, 16],
  "views": {
    "side": {"label": "侧视", "prompt": "true side view facing right"},
    "front": {"label": "正面", "prompt": "true front view facing camera"},
    "three_quarter": {"label": "3/4", "prompt": "three-quarter view facing right"}
  },
  "styles": {
    "hand_drawn": {"label": "手绘高清", "prompt": "hand-painted 2D game character, refined linework, rich controlled shading"},
    "anime": {"label": "动漫赛璐珞", "prompt": "high fidelity anime 2D character, crisp cel shading, precise silhouette"},
    "semi_realistic": {"label": "半写实", "prompt": "semi-realistic 2D character concept art, detailed materials, natural dimensional lighting"}
  },
  "actions": {
    "idle": {"label": "呼吸待机", "loop": true, "anchors": ["neutral inhale", "settled low breath", "neutral transition", "lifted exhale"]},
    "walk": {"label": "行走", "loop": true, "anchors": ["right heel contact", "right leg passing", "left heel contact", "left leg passing"]},
    "run": {"label": "奔跑", "loop": true, "anchors": ["right contact", "first flight", "left contact", "second flight"]},
    "jump": {"label": "跳跃", "loop": false, "anchors": ["deep anticipation", "launch", "apex", "landing compression"]},
    "attack": {"label": "攻击", "loop": false, "anchors": ["ready stance", "attack anticipation", "impact pose", "recovery"]},
    "cast": {"label": "施法", "loop": false, "anchors": ["focus stance", "gathering energy", "spell release", "recovery"]}
  },
  "jobStatuses": ["queued", "planning", "generating", "processing", "awaiting_review", "promoting", "approved", "failed", "interrupted", "cancelled"],
  "imageModels": ["gemini-2.5-flash-image", "gemini-3.1-flash-image-preview", "gemini-3.0-pro-image-preview", "windup-demo-image"]
}
